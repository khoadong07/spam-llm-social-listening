# Copy this file to .env and fill in your actual token
DEEPINFRA_TOKEN=your_deepinfra_token_here

# Redis Configuration - Optimized for high throughput
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=100

# Performance Configuration
MAX_CONCURRENT_REQUESTS=500
MAX_BATCH_SIZE=100
MEMORY_CACHE_SIZE=20000
ENABLE_BATCH_PROCESSING=true